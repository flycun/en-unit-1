# ============================================================
# 数据库连接配置（二选一）
# ============================================================

# ---- 方式 A：本地开发（默认，零配置）----
# 使用项目根目录的 SQLite 文件，适合本地开发与自测。
DATABASE_URL="file:./dev.db"

# ---- 方式 B：生产 / 边缘部署（Turso，推荐用于 EdgeOne Pages）----
# 1. 在 https://turso.tech 注册并创建数据库
# 2. 用 `turso db show <name> --url`     获取 DATABASE_URL
# 3. 用 `turso db tokens create <name>` 获取 TURSO_AUTH_TOKEN
# 4. 注释掉上面的本地 URL，启用下面两行：
# DATABASE_URL="libsql://<your-db>.turso.io"
# TURSO_AUTH_TOKEN="<your-token>"
